# Copiar a .env y completar. El .env NUNCA se commitea.

# Clave de la API de Anthropic (https://console.anthropic.com/)
ANTHROPIC_API_KEY="api-key"

# Modelo de Claude a usar para el parsing estructurado
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Puerto del servidor Fastify
PORT=3000

# Ruta del archivo SQLite (relativa al cwd)
DB_PATH=./vino.sqlite
